    "installer": {
        "script": "Start-Process \"$dir\\$fname\" -ArgumentList '--vivaldi-silent', '--do-not-launch-chrome', '--vivaldi-standalone', \"--vivaldi-install-dir=$dir\" -Wait"
    },
    "post_install": [
