        "Remove-Item \"$fname\", \"Application\\update_notifier.exe\", \"Application\\$version\\Installer\" -Force -Recurse | Out-Null"
    ],
    "post_uninstall": "Remove-Item \"$env:UserProfile\\.vivaldi_reporting_data\" -ErrorAction SilentlyContinue",
    "checkver": {
